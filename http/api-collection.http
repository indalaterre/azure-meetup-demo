### =============================================================================
### MONOLITH — Users (DB: legacymonolith)
### =============================================================================

### [Monolith] List all users
GET {{monolith-jvm}}/api/users

> {%
    client.test("List users", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [Monolith Native] List all users
GET {{monolith-native}}/api/users

> {%
    client.test("Native list users", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [Monolith] Create user
POST {{monolith-jvm}}/api/users
Content-Type: application/json

{
  "username": "mrossi",
  "email": "mario.rossi@cgm.com",
  "fullName": "Mario Rossi",
  "address": "Bari, Italy",
  "phone": "+39 080 123456"
}

> {%
    client.test("Create user", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
        client.assert(response.body.id, "Missing id in response");
    });
    client.global.set("monolith_user_id", response.body.id);
%}

### [Monolith] Get user by ID
GET {{monolith-jvm}}/api/users/{{monolith_user_id}}

> {%
    client.test("Get user by ID", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [Monolith Native] Get user by ID
GET {{monolith-native}}/api/users/{{monolith_user_id}}

> {%
    client.test("Native get user by ID", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [Monolith] Update user
PUT {{monolith-jvm}}/api/users/{{monolith_user_id}}
Content-Type: application/json

{
  "username": "mrossi",
  "email": "mario.rossi@updated.com",
  "fullName": "Mario Rossi Updated",
  "address": "Lecce, Italy",
  "phone": "+39 080 999888"
}

> {%
    client.test("Update user", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [Monolith] Delete user
DELETE {{monolith-jvm}}/api/users/{{monolith_user_id}}

> {%
    client.test("Delete user", function() {
        client.assert(response.status === 204, "Expected 204, got " + response.status);
    });
%}

